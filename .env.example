# bill-n-chill environment template
# Copy to .env.local or .env.prod and adjust values for your environment.

APP_ENV=local

# Host-published ports (set to avoid collisions in local standalone runs)
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# Backend (Django/DRF)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://bnc:bnc_password@127.0.0.1:5432/bill_n_chill
POSTGRES_DB=bill_n_chill
POSTGRES_USER=bnc
POSTGRES_PASSWORD=bnc_password
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Email — local dev uses Mailpit (web UI at http://localhost:8025)
# Prod uses Mailgun HTTP API via django-anymail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@bill-n-chill.com
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_SENDER_DOMAIN=mg.bill-n-chill.com

# Receipt scanning (Gemini Vision)
GEMINI_API_KEY=your-gemini-api-key

# Web Push (VAPID) — generate keys with py_vapid or the script in docs
VAPID_PRIVATE_KEY=base64url-encoded-32-byte-raw-EC-private-key
VAPID_PUBLIC_KEY=base64url-encoded-public-key
VAPID_CLAIM_EMAIL=mailto:support@bill-n-chill.com

# QuickBooks Online sync (dev-only — set QBO_ENABLED=true to activate)
QBO_ENABLED=false
QBO_CLIENT_ID=your-intuit-client-id
QBO_CLIENT_SECRET=your-intuit-client-secret
QBO_REDIRECT_URI=http://localhost:8000/api/v1/qbo/callback/

# Sentry error monitoring
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Backblaze B2 (used by scripts/backup-db.sh and WAL archiving in prod)
# B2_BUCKET_NAME is used by both the backup script and the Postgres WAL archive command.
# B2_KEY_ID and B2_APPLICATION_KEY are used by the WAL archive command inside the DB container.
B2_BUCKET_NAME=bnc-backups
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_VAPID_PUBLIC_KEY=same-URL-safe-base64-public-key-as-VAPID_PUBLIC_KEY
NEXT_PUBLIC_DEBUG=true
