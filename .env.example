# Buildr environment template
# Copy to .env.local or .env.prod and adjust values for your environment.

APP_ENV=local

# Backend (Django/DRF)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DATABASE_URL=sqlite:///backend/db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
