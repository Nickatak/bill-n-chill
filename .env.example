# bill-n-chill environment template
# Copy to .env.local or .env.prod and adjust values for your environment.

APP_ENV=local

# Optional host-published ports (set to avoid collisions in local standalone runs)
FRONTEND_PORT=3000
BACKEND_PORT=8000
MYSQL_PORT=3306

# Backend (Django/DRF)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=mysql://bnc:bnc_password@127.0.0.1:3306/bill_n_chill
MYSQL_DATABASE=bill_n_chill
MYSQL_USER=bnc
MYSQL_PASSWORD=bnc_password
MYSQL_ROOT_PASSWORD=root_password
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email — Mailpit (local dev: web UI at http://localhost:8025)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@bill-n-chill.com
# For prod (Mailgun HTTP API via django-anymail):
# EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
# MAILGUN_API_KEY=key-your-mailgun-api-key
# MAILGUN_SENDER_DOMAIN=mg.bill-n-chill.com
# DEFAULT_FROM_EMAIL=noreply@mg.bill-n-chill.com

# Receipt scanning (Gemini Vision — free tier, optional)
# GEMINI_API_KEY=your-gemini-api-key

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Set to "true" to show dev-only pages (dashboard, bills, event history) in nav
NEXT_PUBLIC_DEBUG=true
