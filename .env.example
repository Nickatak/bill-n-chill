# bill-n-chill environment template
# Copy to .env.local or .env.prod and adjust values for your environment.

APP_ENV=local

# Backend (Django/DRF)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DATABASE_URL=mysql://bnc:bnc_password@127.0.0.1:3306/bill_n_chill
MYSQL_DATABASE=bill_n_chill
MYSQL_USER=bnc
MYSQL_PASSWORD=bnc_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
